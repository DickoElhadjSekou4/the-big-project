<!DOCTYPE html>
<html>
  <head>
    <title>The Big Project</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <%= stylesheet_link_tag "application" %>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">
        <a class="navbar-brand" href="/">The Big Project</a>
        <div class="navbar-nav">
          <%= link_to "Accueil", root_path, class: "nav-link text-white" %>
          <%= link_to "Team", "/team", class: "nav-link text-white" %>
          <%= link_to "Contact", "/contact", class: "nav-link text-white" %>
        </div>
      </div>
    </nav>
    <div class="container mt-4">
      <% if flash[:success] %>
        <div class="alert alert-success"><%= flash[:success] %></div>
      <% end %>
      <% if flash[:error] %>
        <div class="alert alert-danger"><%= flash[:error] %></div>
      <% end %>
      <%= yield %>
    </div>
  </body>
</html>